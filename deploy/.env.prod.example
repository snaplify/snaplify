# ===========================================
# CommonPub Production Environment Variables
# ===========================================

# ---- Core ----
ORIGIN=https://your-domain.com
PORT=3000

# ---- Database ----
POSTGRES_PASSWORD=change-me-strong-password
# DATABASE_URL is auto-composed in docker-compose.prod.yml

# ---- Redis ----
# REDIS_URL is auto-composed in docker-compose.prod.yml

# ---- Auth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-min-32-chars

# ---- Meilisearch ----
# MEILI_URL is auto-composed in docker-compose.prod.yml
# Set explicitly only if using an external Meilisearch instance
# MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=generate-a-strong-key

# ---- Instance Identity ----
INSTANCE_DOMAIN=your-domain.com
INSTANCE_NAME=My CommonPub Instance
INSTANCE_DESCRIPTION=A maker community

# ---- Feature Flags ----
FEATURE_ADMIN=true
FEATURE_FEDERATION=false
FEATURE_COMMUNITIES=true
FEATURE_DOCS=true
FEATURE_LEARNING=true
FEATURE_EXPLAINERS=true

# ---- OAuth Providers (optional) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email (optional — SMTP or Resend) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com
RESEND_API_KEY=

# ---- Storage (S3-compatible — DO Spaces, MinIO, AWS S3) ----
# If S3_BUCKET is empty, uploads go to local filesystem (./uploads/)
S3_BUCKET=
S3_REGION=nyc3
# DO Spaces: https://<region>.digitaloceanspaces.com
# MinIO: http://localhost:9000
# AWS S3: leave blank (uses default)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Public URL for uploaded files. Auto-derived if not set.
# DO Spaces CDN: https://<bucket>.<region>.cdn.digitaloceanspaces.com
S3_PUBLIC_URL=
# Set to true for MinIO (path-style access)
S3_FORCE_PATH_STYLE=false
# Local uploads directory (when not using S3)
UPLOAD_DIR=./uploads

# ---- Analytics (optional) ----
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=
