# ===========================================
# Snaplify Production Environment Variables
# ===========================================

# ---- Core ----
ORIGIN=https://your-domain.com
PORT=3000

# ---- Database ----
POSTGRES_PASSWORD=change-me-strong-password
# DATABASE_URL is auto-composed in docker-compose.prod.yml

# ---- Redis ----
# REDIS_URL is auto-composed in docker-compose.prod.yml

# ---- Auth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-min-32-chars

# ---- Meilisearch ----
# MEILI_URL is auto-composed in docker-compose.prod.yml
# Set explicitly only if using an external Meilisearch instance
# MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=generate-a-strong-key

# ---- Instance Identity ----
INSTANCE_DOMAIN=your-domain.com
INSTANCE_NAME=My Snaplify Instance
INSTANCE_DESCRIPTION=A maker community

# ---- Feature Flags ----
FEATURE_ADMIN=true
FEATURE_FEDERATION=false
FEATURE_COMMUNITIES=true
FEATURE_DOCS=true
FEATURE_LEARNING=true
FEATURE_EXPLAINERS=true

# ---- OAuth Providers (optional) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email (optional) ----
RESEND_API_KEY=

# ---- Storage (optional, S3-compatible) ----
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Analytics (optional) ----
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=
