{
  "name": "@commonpub/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@commonpub/auth": "workspace:*",
    "@commonpub/config": "workspace:*",
    "@commonpub/docs": "workspace:*",
    "@commonpub/learning": "workspace:*",
    "@commonpub/protocol": "workspace:*",
    "@commonpub/schema": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "isomorphic-dompurify": "^3.3.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@types/node": "^25.5.0",
    "@types/sharp": "^0.32.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
