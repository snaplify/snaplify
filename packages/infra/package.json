{
  "name": "@commonpub/infra",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js"
    },
    "./email": {
      "types": "./dist/email.d.ts",
      "import": "./dist/email.js"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "import": "./dist/security.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/sharp": "^0.32.0",
    "typescript": "^5.7.0"
  }
}
