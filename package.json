{
  "name": "commonpub",
  "private": true,
  "description": "Open ActivityPub federation protocol and package suite for self-hosted maker communities",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:infra": "docker compose up -d",
    "dev:app": "turbo run dev --filter=@commonpub/reference",
    "db:push": "pnpm --filter @commonpub/schema db:push",
    "test": "turbo run test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
